{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "logicAppName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Consumption Logic App."
      }
    },
    "automationAccountName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Automation Account."
      }
    },
    "automationAccountResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group of the Automation Account (if different from deployment RG)."
      }
    },
    "runbookName": {
      "type": "string",
      "metadata": {
        "description": "Name of the PowerShell runbook to execute."
      }
    },
    "subscriptionId": {
      "type": "string",
      "defaultValue": "[subscription().subscriptionId]",
      "metadata": {
        "description": "Azure Subscription ID."
      }
    },
    "sentinelResourceGroup": {
      "type": "string",
      "metadata": {
        "description": "Resource group containing the Log Analytics workspace."
      }
    },
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace name for Sentinel."
      }
    },
    "emailRecipient": {
      "type": "string",
      "metadata": {
        "description": "Email address to send the weekly report to."
      }
    },
    "recurrenceIntervalDays": {
      "type": "int",
      "defaultValue": 7,
      "metadata": {
        "description": "Recurrence interval in days for the Logic App trigger."
      }
    },
    "recurrenceHour": {
      "type": "int",
      "defaultValue": 10,
      "metadata": {
        "description": "Hour of the day (0-23) to run the Logic App."
      }
    },
    "recurrenceMinute": {
      "type": "int",
      "defaultValue": 30,
      "metadata": {
        "description": "Minute of the hour (0-59) to run the Logic App."
      }
    },
    "timeZone": {
      "type": "string",
      "defaultValue": "Israel Standard Time",
      "metadata": {
        "description": "Time zone for the recurrence schedule."
      }
    },
    "connectionsResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group for the API connections."
      }
    },
    "_artifactsLocation": {
      "type": "string",
      "defaultValue": "[deployment().properties.templateLink.uri]",
      "metadata": {
        "description": "Base URI where the template and runbook files are located. When deploying from a public GitHub repo, this resolves automatically. For local deployment, provide the raw GitHub URL (e.g., https://raw.githubusercontent.com/OWNER/REPO/main/)."
      }
    }
  },
  "variables": {
    "prefix": "SentinelWeeklyReport-",
    "automationConnectionName": "[concat(variables('prefix'),'azureautomation')]",
    "office365ConnectionName": "[concat(variables('prefix'),'office365')]",
    "automationConnectionId": "[resourceId(parameters('connectionsResourceGroup'), 'Microsoft.Web/connections', variables('automationConnectionName'))]",
    "office365ConnectionId": "[resourceId(parameters('connectionsResourceGroup'), 'Microsoft.Web/connections', variables('office365ConnectionName'))]",
    "automationManagedApiId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('location'), '/managedApis/azureautomation')]",
    "office365ManagedApiId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('location'), '/managedApis/office365')]",
    "sentinelReaderRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'ab8e14d6-4a74-4a29-9ba8-549422addade')]",
    "workspaceId": "[resourceId(parameters('sentinelResourceGroup'), 'Microsoft.OperationalInsights/workspaces', parameters('workspaceName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "sentinelReaderRoleAssignment",
      "resourceGroup": "[parameters('sentinelResourceGroup')]",
      "dependsOn": [
        "[resourceId('Microsoft.Logic/workflows', parameters('logicAppName'))]"
      ],
      "properties": {
        "expressionEvaluationOptions": { "scope": "outer" },
        "mode": "Incremental",
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "resources": [
            {
              "type": "Microsoft.OperationalInsights/workspaces/providers/roleAssignments",
              "apiVersion": "2022-04-01",
              "name": "[concat(parameters('workspaceName'), '/Microsoft.Authorization/', guid(resourceGroup().id, variables('workspaceId'), variables('sentinelReaderRoleId'), parameters('logicAppName')))]",
              "properties": {
                "roleDefinitionId": "[variables('sentinelReaderRoleId')]",
                "principalId": "[reference(resourceId('Microsoft.Logic/workflows', parameters('logicAppName')), '2019-05-01', 'full').identity.principalId]",
                "principalType": "ServicePrincipal"
              }
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts",
      "apiVersion": "2023-11-01",
      "name": "[parameters('automationAccountName')]",
      "location": "[parameters('location')]",
      "dependsOn": [ ],
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "sku": {
          "name": "Basic"
        }
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/runbooks",
      "apiVersion": "2023-11-01",
      "name": "[concat(parameters('automationAccountName'), '/', parameters('runbookName'))]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', parameters('automationAccountName'))]"
      ],
      "properties": {
        "runbookType": "PowerShell",
        "logVerbose": false,
        "logProgress": false,
        "logActivityTrace": 0,
        "description": "Checks Microsoft Sentinel Content Hub for solutions requiring updates and generates an HTML report.",
        "publishContentLink": {
          "uri": "[uri(parameters('_artifactsLocation'), 'Get-SentinelContentUpdates.ps1')]"
        }
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('automationConnectionName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "sentinelweeklyreport-azureautomation",
        "api": {
          "id": "[variables('automationManagedApiId')]"
        },
        "parameterValueType": "Alternative"
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('office365ConnectionName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "sentinelweeklyreport-office365",
        "api": {
          "id": "[variables('office365ManagedApiId')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[parameters('logicAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('automationConnectionName'))]",
        "[resourceId('Microsoft.Web/connections', variables('office365ConnectionName'))]"
      ],
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "state": "Disabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "triggers": {
            "Recurrence": {
              "type": "Recurrence",
              "recurrence": {
                "interval": "[parameters('recurrenceIntervalDays')]",
                "frequency": "Day",
                "schedule": {
                  "hours": [ "[parameters('recurrenceHour')]" ],
                  "minutes": [ "[parameters('recurrenceMinute')]" ]
                },
                "timeZone": "[parameters('timeZone')]"
              },
              "evaluatedRecurrence": {
                "interval": "[parameters('recurrenceIntervalDays')]",
                "frequency": "Day",
                "schedule": {
                  "hours": [ "[parameters('recurrenceHour')]" ],
                  "minutes": [ "[parameters('recurrenceMinute')]" ]
                },
                "timeZone": "[parameters('timeZone')]"
              }
            }
          },
          "actions": {
            "Create_job": {
              "runAfter": {},
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azureautomation']['connectionId']"
                  }
                },
                "method": "put",
                "body": {
                  "properties": {
                    "parameters": {
                      "subscriptionid": "@parameters('SubscriptionId')",
                      "ResourceGroupName": "@parameters('ResourceGroup')",
                      "WorkspaceName": "@parameters('WorkspaceName')"
                    }
                  }
                },
                "path": "[concat('/subscriptions/@{encodeURIComponent(''', parameters('subscriptionId'), ''')}/resourceGroups/@{encodeURIComponent(''', parameters('automationAccountResourceGroup'), ''')}/providers/Microsoft.Automation/automationAccounts/@{encodeURIComponent(''', parameters('automationAccountName'), ''')}/jobs')]",
                "queries": {
                  "x-ms-api-version": "2015-10-31",
                  "runbookName": "[parameters('runbookName')]",
                  "wait": false
                }
              }
            },
            "Delay": {
              "runAfter": {
                "Create_job": [ "Succeeded" ]
              },
              "type": "Wait",
              "inputs": {
                "interval": {
                  "count": 150,
                  "unit": "Second"
                }
              }
            },
            "Get_job_output": {
              "runAfter": {
                "Delay": [ "Succeeded" ]
              },
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azureautomation']['connectionId']"
                  }
                },
                "method": "get",
                "path": "[concat('/subscriptions/@{encodeURIComponent(''', parameters('subscriptionId'), ''')}/resourceGroups/@{encodeURIComponent(''', parameters('automationAccountResourceGroup'), ''')}/providers/Microsoft.Automation/automationAccounts/@{encodeURIComponent(''', parameters('automationAccountName'), ''')}/jobs/@{encodeURIComponent(body(''Create_job'')?[''properties'']?[''jobId''])}/output')]",
                "queries": {
                  "x-ms-api-version": "2015-10-31"
                }
              }
            },
   "Run_KQL_Query": {
     "runAfter": {},
     "type": "Http",
     "inputs": {
       "method": "POST",
       "uri": 
  "https://management.azure.com/subscriptions/@{parameters('SubscriptionId')}/resourceGroups/@{parameters('ResourceGroup')}/provi
  ders/Microsoft.OperationalInsights/workspaces/@{parameters('WorkspaceName')}/api/query?api-version=2017-01-01-preview",
       "body": {
         "query": "let Pricing=5.56;\nlet CurrentWeekStart = startofweek(now());\nlet PreviousWeekStart = startofweek(now()) - 7d;\nlet CurrentWeek=Usage\n    | where TimeGenerated >= CurrentWeekStart\n    | where IsBillable == true\n    | summarize CurrentGB = round(sum(Quantity) / 1024, 2) by DataType\n    | extend Cost=CurrentGB*Pricing\n| extend x=1\n| as T\n| join kind=inner (\n       T\n       | summarize WeekTotalGB = sum(CurrentGB),x=1\n   ) on x\n   | project-away x*   \n| extend PercentOfTotal = round(CurrentGB / WeekTotalGB * 100, 2)\n| join kind=fullouter (Usage\n    | where TimeGenerated >= PreviousWeekStart and TimeGenerated < CurrentWeekStart\n    | where IsBillable == true\n    | summarize PreviousGB = round(sum(Quantity) / 1024, 2) by DataType\n    ) on DataType\n| extend DataType = coalesce(DataType, DataType1)\n| extend CurrentGB = coalesce(CurrentGB, 0.0), PreviousGB = coalesce(PreviousGB, 0.0)\n| extend ChangeGB = round(CurrentGB - PreviousGB, 2)\n| extend ChangePercent = iff(PreviousGB > 0, round((CurrentGB - PreviousGB) / PreviousGB * 100, 2), 0.0)\n| where CurrentGB != 0 and PreviousGB != 0\n| project DataType, PreviousGB,CurrentGB, ChangeGB,ChangePercent,PercentOfTotal,Cost;\nCurrentWeek\n| union  (CurrentWeek | summarize CurrentGB=sum(CurrentGB),PreviousGB=sum(PreviousGB),DataType=' Total',Cost=sum(Cost),PercentOfTotal=sum(PercentOfTotal)\n| extend ChangeGB = round(CurrentGB - PreviousGB, 2)\n| extend ChangePercent = iff(PreviousGB > 0, round((CurrentGB - PreviousGB) / PreviousGB * 100, 2), 0.0))\n| order by CurrentGB desc\n| project Table=DataType, ['Previous Week (GB)']=PreviousGB,['Current Week (GB)']= round(CurrentGB,2), ['Change (GB)']=round(ChangeGB,2),['Change Percent']=strcat(ChangePercent,'%'),['Total Percent']=strcat(PercentOfTotal,'%'),['Estimated Cost']=strcat('$',round(Cost,2))"
       },
       "authentication": {
         "type": "ManagedServiceIdentity",
         "audience": "https://management.azure.com/"
       }
     }
     },
   "Transform_KQL_Results": {
     "runAfter": { "Run_KQL_Query": ["Succeeded"] },
     "type": "Select",
     "inputs": {
       "from": "@body('Run_KQL_Query')?['tables']?[0]?['rows']",
       "select": {
         "Table": "@item()?[0]",
         "Previous Week (GB)": "@item()?[1]",
         "Current Week (GB)": "@item()?[2]",
         "Change (GB)": "@item()?[3]",
         "Change Percent": "@item()?[4]",
         "Total Percent": "@item()?[5]",
         "Estimated Cost": "@item()?[6]"
       }
     }
     },
   
            "Create_Mini_HTML_table": {
                "runAfter": {
                    "Transform_KQL_Results": [
                        "Succeeded"
                    ]
                },
                "type": "Table",
                "inputs": {
                    "from": "@take(skip(body('Transform_KQL_Results'),1),5)",
                    "format": "HTML"
                }
            },
            "Initialize_Mini_HTML": {
                "runAfter": {
                    "Create_Mini_HTML_table": [
                        "Succeeded"
                    ]
                },
                "type": "InitializeVariable",
                "inputs": {
                    "variables": [
                        {
                            "name": "MiniHTMLBody",
                            "type": "string",
                            "value": "@{substring(body('Create_Mini_HTML_table'), 0, sub(length(body('Create_Mini_HTML_table')), 8))}\n<tr><th>@{first(body('Transform_KQL_Results'))?['Table']}</th>\n<th>@{first(body('Transform_KQL_Results'))?['Previous Week (GB)']}</th>\n<th>@{first(body('Transform_KQL_Results'))?['Current Week (GB)']}</th>\n<th>@{first(body('Transform_KQL_Results'))?['Change (GB)']}</th>\n<th>@{first(body('Transform_KQL_Results'))?['Change Percent']}</th>\n<th>@{first(body('Transform_KQL_Results'))?['Total Percent']}</th><th>@{first(body('Transform_KQL_Results'))?['Estimated Cost']}</th></tr></table>"
                        }
                    ]
                }
            },
            "Create_HTML_table": {
              "runAfter": {
                "Transform_KQL_Results": [ "Succeeded" ]
              },
              "type": "Table",
              "inputs": {
                "from": "@skip(body('Transform_KQL_Results'),1)",
                "format": "HTML"
              }
            },
            "Initialize_HTML": {
              "runAfter": {
                "Create_HTML_table": [ "Succeeded" ]
              },
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "HTMLBody",
                    "type": "string",
                    "value": "@{substring(body('Create_HTML_table'), 0, sub(length(body('Create_HTML_table')), 8))}\n<tr><th>@{first(body('Transform_KQL_Results'))?['Table']}</th>\n<th>@{first(body('Transform_KQL_Results'))?['Previous Week (GB)']}</th>\n<th>@{first(body('Transform_KQL_Results'))?['Current Week (GB)']}</th>\n<th>@{first(body('Transform_KQL_Results'))?['Change (GB)']}</th>\n<th>@{first(body('Transform_KQL_Results'))?['Change Percent']}</th>\n<th>@{first(body('Transform_KQL_Results'))?['Total Percent']}</th><th>@{first(body('Transform_KQL_Results'))?['Estimated Cost']}</th></tr></table>"
                  }
                ]
              }
            },
            "Send_an_email_(V2)": {
              "runAfter": {
                    "Initialize_HTML": [
                        "Succeeded"
                    ],
                    "Initialize_Mini_HTML": [
                        "Succeeded"
                    ],
                    "Get_job_output": [
                        "Succeeded"
                    ]
                },
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['office365']['connectionId']"
                  }
                },
                "method": "post",
                "body": {
                  "To": "[parameters('emailRecipient')]",
                        "Subject": "Microsoft Sentinel Weekly Summary",
                        "Body": "<style>\nbody { font-family: Segoe UI, Arial, sans-serif; font-size: 14px; color: #333; }\nh1 { color: #0066cc; }\nh2 { color: #0078D4; margin-bottom: 4px; }\ntable { border-collapse: collapse; width: 100%; margin-top: 10px; }\nth { background-color: #0078D4; color: #fff; padding: 10px 12px; text-align: left; }\ntd { padding: 8px 12px; border-bottom: 1px solid #ddd; }\ntr:nth-child(even) { background-color: #f5f5f5; }\n.summary { margin: 20px 0; padding: 10px; background-color: #f0f8ff; border-left: 5px solid #0066cc; }\n</style>\n<h1>Microsoft Sentinel Weekly Report</h1>\n<div class=\"summary\">\n<p>Sentinel Workspace Name: @{parameters('WorkspaceName')}</p>\n<p>Report Generated: @{\nformatDateTime(\n  convertTimeZone(utcNow(), 'UTC','Israel Standard Time'),\n  'HH:mm:ss dd-MM-yyyy'\n)\n}</p>\n</div>\n<h2>📊 Weekly Ingestion Report</h2>\n<p>Comparison of current week vs. previous week.</p>\n@{variables('MiniHTMLBody')}\n<br>\n@{decodeBase64(json(body('Get_job_output'))?['MiniHtml'])}\n\n",
                        "Attachments": [
                            {
                                "Name": "SentinelReport-@{formatDateTime(convertTimeZone(utcNow(), 'UTC','Israel Standard Time'),'dd-MM-yyyy')}.html",
                                "ContentBytes": "@base64(concat('<style>','\n','body { font-family: Segoe UI, Arial, sans-serif; font-size: 14px; color: #333; }','\n','h1 { color: #0066cc; }','\n','h2 { color: #0078D4; margin-bottom: 4px; }','\n','table { border-collapse: collapse; width: 100%; margin-top: 10px; }','\n','th { background-color: #0078D4; color: #fff; padding: 10px 12px; text-align: left; }','\n','td { padding: 8px 12px; border-bottom: 1px solid #ddd; }','\n','tr:nth-child(even) { background-color: #f5f5f5; }','\n','.summary { margin: 20px 0; padding: 10px; background-color: #f0f8ff; border-left: 5px solid #0066cc; }','\n','</style>','\n','\n','<h1>Microsoft Sentinel Weekly Report</h1>','\n','<div class=\"summary\">','\n','<p>Sentinel Workspace Name: ',parameters('WorkspaceName'),'</p>','\n','<p>Report Generated: ',\nformatDateTime(\n  convertTimeZone(utcNow(), 'UTC','Israel Standard Time'),\n  'HH:mm:ss dd-MM-yyyy'\n)\n,'</p>','\n','</div>','\n','<h2>📊 Weekly Ingestion Report</h2>','\n','<p>Comparison of current week vs. previous week.</p>','\n',variables('HTMLBody'),'\n','<br>','\n',decodeBase64(json(body('Get_job_output'))?['FullHtml']),'\n','<br>'))"
                            }
                        ],
                  "Importance": "Normal"
                },
                "path": "/v2/Mail"
              }
            }
          },
          "outputs": {},
          "parameters": {
            "SubscriptionId": {
              "defaultValue": "[parameters('subscriptionId')]",
              "type": "String"
            },
            "ResourceGroup": {
              "defaultValue": "[parameters('sentinelResourceGroup')]",
              "type": "String"
            },
            "WorkspaceName": {
              "defaultValue": "[parameters('workspaceName')]",
              "type": "String"
            },
            "$connections": {
              "type": "Object",
              "defaultValue": {}
            }
          }
        },
        "parameters": {
          "$connections": {
            "value": {
              "azureautomation": {
                "id": "[variables('automationManagedApiId')]",
                "connectionId": "[variables('automationConnectionId')]",
                "connectionName": "[variables('automationConnectionName')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              },
              "office365": {
                "id": "[variables('office365ManagedApiId')]",
                "connectionId": "[variables('office365ConnectionId')]",
                "connectionName": "[variables('office365ConnectionName')]",
                "connectionProperties": {}
              }
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "managedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Logic/workflows', parameters('logicAppName')), '2019-05-01', 'full').identity.principalId]"
    },
    "logicAppId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Logic/workflows', parameters('logicAppName'))]"
    },
    "automationAccountId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Automation/automationAccounts', parameters('automationAccountName'))]"
    }
  }
}








